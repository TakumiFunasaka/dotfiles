#!/usr/bin/env python3
"""x - Terminal mini-games (Wordle, Snake, 2048)"""

import curses
import random
import time

# ── Color pair IDs ────────────────────────────────────────────

C_CORRECT = 1
C_PRESENT = 2
C_SNAKE = 3
C_FOOD = 4

